---
import Titles from "@/components/text/Titles.astro"
import { RESOURCES } from "@/data/resources"
import { SECTIONS } from "@/constants"
import { TYPE_CONTENT } from "@/interfaces/Directory"
import { IconArrowUpRight } from "@tabler/icons-react"

const totalResources = RESOURCES.reduce(
	(total, category) => total + category.items.length,
	0,
)
---

<section id={SECTIONS.RESOURCES}>
	<Titles
		title="Recursos"
		subtitle="Herramientas, referencias y personas que vuelven más útil mi trabajo diario."
	/>

	<div class="resource-summary">
		<p>
			Una biblioteca personal en constante cambio. Cada enlace está aquí porque
			lo uso, aprendí algo de él o merece ser compartido.
		</p>
		<span>{totalResources} recomendaciones · {RESOURCES.length} categorías</span>
	</div>

	<div class="resource-grid">
		{
			RESOURCES.map((category) => (
				<article class="resource-group">
					<header>
						<h3>{category.title}</h3>
						<span>{String(category.items.length).padStart(2, "0")}</span>
					</header>

					<div class="resource-links">
						{category.items.map((item) => {
							if (item.type !== TYPE_CONTENT.ANCHOR) return null
							const [name, ...descriptionParts] = item.title.split(" - ")
							const description = descriptionParts.join(" — ")

							return (
								<a href={item.url} target="_blank" rel="noreferrer">
									<img
										src={item.image}
										alt=""
										width="36"
										height="36"
										loading="lazy"
									/>
									<span>
										<strong>{name}</strong>
										{description && <small>{description}</small>}
									</span>
									<IconArrowUpRight size={18} />
								</a>
							)
						})}
					</div>
				</article>
			))
		}
	</div>
</section>

<style>
	.resource-summary {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 2rem;
		margin-bottom: clamp(2.5rem, 6vw, 4.5rem);
	}

	.resource-summary p {
		max-width: 58ch;
		color: var(--title-color);
		font-size: clamp(1.1rem, 2vw, 1.4rem);
		line-height: 1.55;
	}

	.resource-summary > span {
		flex: 0 0 auto;
		color: var(--text-color-light);
		font-family: "Cascadia Code", monospace;
		font-size: 0.7rem;
	}

	.resource-grid {
		columns: 3 19rem;
		column-gap: 1rem;
	}

	.resource-group {
		display: inline-block;
		width: 100%;
		margin-bottom: 1rem;
		padding: clamp(1.1rem, 2vw, 1.5rem);
		break-inside: avoid;
		border-radius: 14px;
		background: color-mix(in srgb, var(--container-color) 78%, var(--body-color));
	}

	.resource-group header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 1rem;
		padding-bottom: 0.85rem;
		border-bottom: 1px solid var(--border-color);
	}

	.resource-group h3 {
		font-size: 1rem;
		letter-spacing: -0.01em;
	}

	.resource-group header span {
		color: var(--first-color);
		font-family: "Cascadia Code", monospace;
		font-size: 0.68rem;
	}

	.resource-links {
		display: grid;
		gap: 0.3rem;
	}

	.resource-links a {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		align-items: center;
		gap: 0.75rem;
		margin-inline: -0.5rem;
		padding: 0.65rem 0.5rem;
		border-radius: 9px;
		color: var(--text-color);
		transition:
			transform 0.2s ease,
			background-color 0.2s ease;
	}

	.resource-links a:hover {
		background: var(--body-color);
		transform: translateX(3px);
	}

	.resource-links img {
		width: 2.25rem;
		height: 2.25rem;
		padding: 0.25rem;
		border-radius: 8px;
		background: var(--body-color);
		object-fit: contain;
	}

	.resource-links a > span {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.resource-links strong {
		color: var(--title-color);
		font-size: 0.82rem;
		font-weight: 600;
	}

	.resource-links small {
		margin-top: 0.1rem;
		color: var(--text-color-light);
		font-size: 0.68rem;
		line-height: 1.4;
	}

	.resource-links svg {
		color: var(--text-color-light);
		transition: color 0.2s ease;
	}

	.resource-links a:hover svg {
		color: var(--first-color);
	}

	@media (max-width: 680px) {
		.resource-summary {
			align-items: flex-start;
			flex-direction: column;
		}

		.resource-grid {
			columns: 1;
		}
	}
</style>
