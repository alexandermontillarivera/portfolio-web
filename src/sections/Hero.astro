---
import Link from "@/components/elements/Link.astro"
import Tooltip from "@/components/elements/Tooltip.astro"
import { IconArrowDown, IconDownload, IconMail } from "@tabler/icons-react"
import { SOCIAL_MEDIA } from "@/data/hero"
import { SECTIONS } from "@/constants"
---

<section id={SECTIONS.HERO}>
	<div class="hero-copy">
		<p class="availability"><span></span> Disponible para nuevos proyectos</p>
		<h1>Convierto ideas complejas en productos <em>claros.</em></h1>
		<p class="intro">
			Soy Alexander, desarrollador Full Stack en República Dominicana. Diseño y
			construyo aplicaciones rápidas, mantenibles y pensadas para las personas
			que las usan.
		</p>

		<div class="actions">
			<Link href={`#${SECTIONS.PROJECTS}`} variant="flex">
				Ver proyectos <IconArrowDown />
			</Link>
			<a class="contact-link" href="mailto:info@alexandermontillarivera.com">
				<IconMail /> Escribirme
			</a>
		</div>

		<div class="social">
			{
				SOCIAL_MEDIA.map((item) => (
					<Tooltip text={`Visitar ${item.name}`}>
						<a
							href={item.url}
							target="_blank"
							rel="noreferrer"
							class="socialIcon"
							aria-label={`Visitar ${item.name}`}
						>
							<item.icon />
						</a>
					</Tooltip>
				))
			}
		</div>
	</div>

	<aside class="portrait">
		<div class="image-frame">
			<img
				src="/me.png"
				alt="Alexander Montilla, desarrollador Full Stack"
				width="540"
				height="620"
			/>
			<span>Full Stack<br />Developer</span>
		</div>

		<a class="cv-link" href="/cv.pdf" download="cv-alexander-montilla.pdf">
			<IconDownload /> Descargar CV
		</a>
	</aside>
</section>

<style>
	section {
		align-items: center;
		display: grid;
		grid-template-columns: minmax(0, 1.55fr) minmax(14rem, 0.45fr);
		gap: clamp(3rem, 8vw, 7rem);
		min-height: min(900px, 100dvh);
		padding-bottom: clamp(4rem, 8vw, 7rem);
	}

	.hero-copy {
		min-width: 0;
	}

	h1 {
		font-size: var(--big-font-size);
		max-width: 13ch;
		letter-spacing: -0.04em;
	}

	h1 em {
		color: var(--first-color);
		font-style: normal;
	}

	.availability {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		margin-bottom: 1.5rem;
		font-size: 0.85rem;
		font-weight: 600;
	}

	.availability span {
		width: 0.65rem;
		aspect-ratio: 1;
		border-radius: 50%;
		background: #3b9a62;
		box-shadow: 0 0 0 5px color-mix(in srgb, #3b9a62 18%, transparent);
	}

	.intro {
		max-width: 59ch;
		font-size: clamp(1rem, 1.6vw, 1.2rem);
		margin-top: 1.75rem;
	}

	.actions {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 1.5rem;
		margin-top: 2rem;
	}

	.contact-link,
	.cv-link {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--title-color);
		font-weight: 600;
		text-decoration: underline;
		text-underline-offset: 0.3em;
	}

	.portrait {
		position: relative;
		width: clamp(14rem, 20vw, 17rem);
		justify-self: end;
	}

	.image-frame {
		position: relative;
		overflow: hidden;
		background: var(--first-color);
		border-radius: 14px;
		aspect-ratio: 4 / 5;
	}

	.image-frame img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center top;
		filter: saturate(0.9);
	}

	.image-frame span {
		position: absolute;
		inset: auto 1rem 1rem auto;
		padding: 0.6rem 0.75rem;
		background: var(--title-color);
		color: var(--body-color);
		border-radius: 6px;
		font-family: "Cascadia Code", monospace;
		font-size: 0.62rem;
		line-height: 1.4;
	}

	.cv-link {
		margin-top: 1.25rem;
		font-size: 0.9rem;
	}

	.social {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-top: 2rem;
	}

	.socialIcon {
		display: grid;
		place-items: center;
		font-size: 1.2rem;
		color: var(--text-color);
		transition:
			color 0.2s ease,
			transform 0.2s ease;
	}

	.socialIcon:hover {
		color: var(--first-color);
		transform: translateY(-2px);
	}

	@media screen and (min-width: 681px) and (max-width: 998px) {
		section {
			grid-template-columns: minmax(0, 1.35fr) minmax(13.5rem, 0.65fr);
			gap: clamp(2rem, 5vw, 3.25rem);
			min-height: min(780px, 100dvh);
			padding-top: calc(var(--header-height) + 2rem);
		}

		.portrait {
			width: min(100%, 15.5rem);
			justify-self: end;
		}

		h1 {
			font-size: clamp(2.65rem, 6vw, 3.65rem);
		}

		.intro {
			font-size: 1rem;
		}

		.actions {
			gap: 1rem;
		}
	}

	@media screen and (max-width: 680px) {
		section {
			grid-template-columns: 1fr;
			padding-top: calc(var(--header-height) + 1.5rem);
			min-height: auto;
		}

		.portrait {
			width: min(82%, 17rem);
			justify-self: center;
		}
	}

	@media screen and (max-width: 540px) {
		section {
			gap: 3rem;
		}

		h1 {
			font-size: clamp(2.55rem, 12vw, 3.35rem);
			max-width: none;
		}

		.portrait {
			width: 100%;
		}

		.image-frame {
			aspect-ratio: 5 / 4;
		}

	}
</style>
