---
import { IconBrandGithub } from "@tabler/icons-react"
const year = new Date().getFullYear()
---

<footer>
	<div>
		<p class="footer-title">¿Construimos algo útil?</p>
		<a class="email" href="mailto:info@alexandermontillarivera.com">Hablemos por correo</a>
	</div>
	<p class="copyright">© {year} Alexander Montilla Rivera</p>
	<a
		href="https://github.com/alexandermontillarivera/portfolio-web"
		target="_blank"
		rel="noreferrer"
		aria-label="Ver el código de este portfolio en GitHub"
	>
		<IconBrandGithub size={28} />
	</a>
</footer>

<style>
	footer {
		max-width: 1200px;
		margin: 0 auto;
		padding: 3rem 0;
		border-top: 1px solid var(--border-color);
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
	}

	.footer-title {
		color: var(--title-color);
		font-size: 1.5rem;
		font-weight: 600;
	}

	.email {
		text-decoration: underline;
		text-underline-offset: 0.25em;
	}

	.copyright {
		margin-left: auto;
		font-size: 0.85rem;
	}

	a {
		color: var(--first-color);
		transition:
			opacity 0.4s ease,
			transform 0.4s ease;
	}

	a:hover {
		opacity: 0.7;
		transform: translateY(-3px);
	}

	@media screen and (max-width: 1248px) {
		footer {
			margin-inline: 2rem;
		}
	}

	@media screen and (max-width: 640px) {
		footer {
			align-items: center;
			flex-direction: column;
			text-align: center;
		}

		footer > div {
			display: grid;
			justify-items: center;
		}

		.copyright {
			margin-left: 0;
		}
	}
</style>
