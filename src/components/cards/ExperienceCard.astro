---
import dayjs from "dayjs"
import Tag from "@/components/elements/Tag.astro"
import { FORMAT_DATE_EXPERIENCE } from "@/constants"
import { type IExperience } from "@/interfaces/Experience"
import { convertFirstLetterToUppercase } from "@/utils/string"

interface Props {
	data: IExperience
}

const {
	title,
	company,
	endDate,
	startDate,
	achievement,
	technologies,
	responsibilities,
} = Astro.props.data

const formatedStartDate = dayjs(startDate).format(FORMAT_DATE_EXPERIENCE)
const formattedEndDate = endDate
	? dayjs(endDate).format(FORMAT_DATE_EXPERIENCE)
	: "Presente"
---

<article class="experience-card">
	<div class="role-meta">
		<span class="duration">
			{convertFirstLetterToUppercase(formatedStartDate)} -
			{convertFirstLetterToUppercase(formattedEndDate)}
		</span>
		<p>{company}</p>
	</div>

	<div class="role-content">
		<header>
			<h3>{title}</h3>
		</header>

		<div class="responsibilities">
			<h4>En el día a día</h4>
			<ul>
				{responsibilities.map((responsibility) => <li>{responsibility}</li>)}
			</ul>
		</div>
		{
			achievement && (
				<div class="achievement">
					<h4>Resultado destacado</h4>
					<p>{achievement}</p>
				</div>
			)
		}
		<footer class="technologies">
			<h4>Tecnologías</h4>
			<ul>
				{
					technologies.map((tech) => (
						<li>
							<Tag>{tech}</Tag>
						</li>
					))
				}
			</ul>
		</footer>
	</div>
</article>

<style>
	.experience-card {
		display: grid;
		grid-template-columns: minmax(11rem, 0.42fr) minmax(0, 1.58fr);
		gap: clamp(2rem, 6vw, 6rem);
		width: 100%;
		padding: clamp(2rem, 5vw, 4.5rem) 0;
		border-top: 1px solid var(--border-color);
	}

	.experience-card:last-child {
		border-bottom: 1px solid var(--border-color);
	}

	.experience-card:first-child {
		border-top: 0;
	}

	.role-meta {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.role-meta p {
		color: var(--title-color);
		font-weight: 600;
	}

	.role-content > header {
		margin-bottom: 2rem;
	}

	.role-content > header h3 {
		font-size: clamp(1.75rem, 3vw, 2.5rem);
		color: var(--first-color);
	}

	.duration {
		color: var(--text-color-light);
		font-family: "Cascadia Code", monospace;
		font-size: 0.75rem;
		line-height: 1.5;
	}

	h4 {
		margin-bottom: 0.85rem;
		font-size: 0.9rem;
		letter-spacing: 0;
	}

	.responsibilities {
		margin-bottom: 2rem;
	}

	.responsibilities ul {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.75rem 2rem;
	}

	.responsibilities li {
		position: relative;
		padding-left: 1.15rem;
	}

	.responsibilities li::before {
		content: "";
		position: absolute;
		top: 0.72em;
		left: 0;
		width: 0.35rem;
		height: 0.35rem;
		border-radius: 50%;
		background: var(--first-color);
	}

	.technologies ul {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.achievement {
		margin-bottom: 2rem;
		padding: clamp(1.25rem, 3vw, 1.75rem);
		background: var(--constras-color);
		border-radius: 10px;
	}

	.achievement p {
		max-width: 72ch;
	}

	@media (max-width: 720px) {
		.experience-card {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}

		.responsibilities ul {
			grid-template-columns: 1fr;
		}
	}
</style>
