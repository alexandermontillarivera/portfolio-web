---
import { ITechSkill } from "@/interfaces/TechSkill"
import { IconArrowUpRight } from "@tabler/icons-react"

export interface Props {
	data: ITechSkill
	index: number
}

const { data, index } = Astro.props
const { icon: Icon, name, type, web } = data
---

<a
	target="_blank"
	rel="noreferrer"
	referrerpolicy="no-referrer"
	href={web}
	data-type={type}
	aria-label={`Abrir sitio oficial de ${name}`}
>
	<div class="skill-topline">
		<span>{String(index).padStart(2, "0")}</span>
		<IconArrowUpRight className="external-icon" size={18} strokeWidth={1.5} />
	</div>

	<div class="skill-identity">
		<div class="icon-wrap">
			<Icon size={34} strokeWidth={1.45} />
		</div>
		<div>
			<p>{name}</p>
			<small>{type}</small>
		</div>
	</div>
</a>

<style>
	a {
		display: flex;
		min-width: 0;
		min-height: 10.5rem;
		flex-direction: column;
		justify-content: space-between;
		gap: 1.5rem;
		padding: 1.15rem;
		color: var(--text-color);
		cursor: pointer;
		transition:
			background-color 0.2s ease,
			color 0.3s ease,
			transform 0.2s ease;
	}

	a:hover {
		z-index: 1;
		background: var(--body-color);
		color: var(--first-color);
		transform: translateY(-2px);
	}

	a:active {
		transform: translateY(0) scale(0.99);
	}

	.skill-topline {
		display: flex;
		align-items: center;
		justify-content: space-between;
		color: var(--text-color-light);
		font-family: "Cascadia Code", monospace;
		font-size: 0.66rem;
	}

	.external-icon {
		opacity: 0;
		transform: translate(-4px, 4px);
		transition:
			opacity 0.2s ease,
			transform 0.2s ease;
	}

	a:hover .external-icon,
	a:focus-visible .external-icon {
		opacity: 1;
		transform: translate(0, 0);
	}

	.skill-identity {
		display: flex;
		align-items: center;
		gap: 0.85rem;
	}

	.icon-wrap {
		display: grid;
		width: 3rem;
		height: 3rem;
		flex: 0 0 auto;
		place-items: center;
		border: 1px solid
			color-mix(in srgb, var(--border-color) 58%, transparent);
		border-radius: 12px;
		background: var(--container-color);
		color: var(--title-color);
		transition:
			border-color 0.2s ease,
			color 0.2s ease;
	}

	a:hover .icon-wrap {
		border-color: color-mix(in srgb, var(--first-color) 55%, transparent);
		color: var(--first-color);
	}

	p {
		color: var(--title-color);
		font-size: 0.92rem;
		font-weight: 600;
		line-height: 1.25;
	}

	small {
		display: block;
		margin-top: 0.2rem;
		color: var(--text-color-light);
		font-family: "Cascadia Code", monospace;
		font-size: 0.62rem;
		line-height: 1.3;
	}

	@media screen and (max-width: 560px) {
		a {
			min-height: auto;
			flex-direction: row-reverse;
			align-items: center;
			gap: 1rem;
			padding: 1rem;
		}

		.skill-topline {
			flex: 0 0 auto;
		}

		.skill-topline > span {
			display: none;
		}

		.external-icon {
			opacity: 1;
			transform: none;
		}

		.skill-identity {
			margin-right: auto;
		}
	}
</style>
