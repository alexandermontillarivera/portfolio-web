---
import Link from "@/components/elements/Link.astro"
import Tag from "@/components/elements/Tag.astro"
import { type IEducation } from "@/interfaces/Education"
import { IconDownload } from "@tabler/icons-react"
interface Props {
	data: IEducation
}

const { title, institution, year, skills, description, certificate, image } =
	Astro.props.data

const nameDownload = `${title.replace(/ /g, "-").toLowerCase()}.pdf`
const visibleSkills = skills.slice(0, 4)
const remainingSkills = skills.slice(4)
---

<article class="education-card">
	<header>
		<div class="logo">
			<img src={image} alt={title} loading="lazy" width="50" height="50" />
		</div>
		<Tag>{year ?? "Actualidad"}</Tag>
	</header>

	<div class="content">
		<p class="institution">{institution}</p>
		<h3>{title}</h3>
		<p class="description">{description}</p>

		<ul class="skills">
			{visibleSkills.map((skill) => <li>{skill}</li>)}
		</ul>
		{
			remainingSkills.length > 0 && (
				<details>
					<summary>Ver {remainingSkills.length} habilidades más</summary>
					<ul class="skills additional-skills">
						{remainingSkills.map((skill) => <li>{skill}</li>)}
					</ul>
				</details>
			)
		}
	</div>
	<footer>
		{
			certificate && (
				<Link href={certificate} variant="small-flex" download={nameDownload}>
					Descargar Certificado <IconDownload />
				</Link>
			)
		}
	</footer>
</article>

<style>
	article {
		background: color-mix(in srgb, var(--container-color) 78%, var(--body-color));
		border-radius: 14px;
		display: flex;
		flex-direction: column;
		padding: clamp(1.25rem, 3vw, 2rem);
		min-height: 100%;
		transition:
			transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
			background-color 0.3s ease;
	}

	article:hover {
		transform: translateY(-4px);
		background: var(--container-color);
	}

	header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		margin-bottom: clamp(1.5rem, 4vw, 3rem);
	}

	.logo {
		display: grid;
		place-items: center;
		width: 3.75rem;
		aspect-ratio: 1;
		padding: 0.5rem;
		border-radius: 10px;
		background: var(--body-color);
	}

	img {
		object-fit: contain;
		width: 100%;
		height: 100%;
	}

	h3 {
		color: var(--title-color);
		font-size: clamp(1.35rem, 2.3vw, 1.85rem);
		font-weight: 600;
		margin-bottom: 0.85rem;
	}

	.institution {
		color: var(--first-color);
		font-size: 0.82rem;
		font-weight: 600;
		margin-bottom: 0.45rem;
	}

	.description {
		max-width: 58ch;
		margin-bottom: 1.5rem;
	}

	.skills {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem 1rem;
		font-size: 0.82rem;
	}

	.skills li {
		position: relative;
		padding-left: 0.75rem;
	}

	.skills li::before {
		content: "•";
		position: absolute;
		left: 0;
		color: var(--first-color);
	}

	details {
		margin-top: 0.9rem;
	}

	summary {
		width: fit-content;
		color: var(--text-color);
		cursor: pointer;
		font-size: 0.82rem;
		font-weight: 600;
		text-decoration: underline;
		text-underline-offset: 0.25em;
	}

	.additional-skills {
		margin-top: 0.75rem;
	}

	footer {
		margin-top: auto;
		padding-top: 1.75rem;
		display: flex;
		justify-content: flex-start;
	}
</style>
