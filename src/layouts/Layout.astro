---
import "@fontsource/poppins"
import Menu from "@/components/nav/Menu.astro"
import Analytics from "@vercel/analytics/astro"
import Footer from "@/components/footer/Footer.astro"
import FloatingControls from "@/components/elements/FloatingControls.astro"
import SpeedInsights from "@vercel/speed-insights/astro"
import { THEME_STORAGE_NAME, THEME, DARK_THEME_CLASS_NAME } from "@/constants"
import { ClientRouter } from "astro:transitions"

interface Props {
	content?: boolean
	hideMenuItems?: boolean
}

const { content = true, hideMenuItems = false } = Astro.props
---

<!doctype html>
<html lang="es">
	<head>
		<title>Alexander Montilla — Desarrollador Full Stack</title>
		<meta charset="UTF-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#f36f2b" />
		<meta name="generator" content={Astro.generator} />
		<meta name="title" content="Alexander Montilla Rivera 👨‍💻" />
		<meta
			name="description"
			content="Portfolio de Alexander Montilla, desarrollador Full Stack especializado en crear productos web rápidos, mantenibles y centrados en las personas."
		/>
		<meta
			name="keywords"
			content="¿Quien es Alexander Montilla Rivera?, Alexander Montilla Rivera, Alexander Montilla"
		/>
		<meta property="og:type" content="Website" />
		<meta property="og:url" content="https://alexandermontillarivera.com" />
		<meta property="og:title" content="Alexander Montilla Rivera 👨‍💻" />
		<meta
			property="og:description"
			content="Desarrollador Full Stack. Productos web rápidos, mantenibles y centrados en las personas."
		/>
		<meta property="og:image" content="https://alexandermontillarivera.com/me.png" />
		<meta name="twitter:card" content="summary_large_image" />

		<ClientRouter />
	</head>
	<body>
		<a class="skip-link" href="#main-content">Saltar al contenido</a>
		<script define:vars={{ THEME_STORAGE_NAME, THEME, DARK_THEME_CLASS_NAME }}>
			const theme = (() => {
				const currentTheme = localStorage.getItem(THEME_STORAGE_NAME)

				if (currentTheme) {
					return currentTheme
				}

				return window.matchMedia("(prefers-color-scheme: dark)").matches
					? THEME.DARK
					: THEME.LIGHT
			})()

			if (theme === THEME.DARK) {
				document.body.classList.add(DARK_THEME_CLASS_NAME)
			}
		</script>

		{
			content ? (
				<>
					<Menu hideMenuItems={hideMenuItems} />
					<div class="content-wrapper">
						<main id="main-content">
							<slot />
						</main>
					</div>
					<Footer server:defer />
					<FloatingControls />
				</>
			) : (
				<slot />
			)
		}

		<Analytics />
		<SpeedInsights />
		<script>
			import "@/scripts/webmcp"
		</script>
	</body>
</html>

<style is:global>
	:root {
		--header-height: 4.75rem;
		--hue-color: 28;
		--first-color: #c34708;
		--first-color-second: #c34708;
		--first-color-alt: #b83f05;
		--first-color-lighter: #ffd9c5;
		--title-color: #171513;
		--text-color: #5a5550;
		--text-color-light: #706a64;
		--input-color: #f4f1ee;
		--body-color: #f8f7f5;
		--border-color: rgba(55, 45, 38, 0.2);
		--container-color: #ffffff;
		--scroll-bar-color: hsl(var(--hue-color), 12%, 90%);
		--scroll-thumb-color: hsl(var(--hue-color), 12%, 80%);
		--body-font: "Poppins", sans-serif;
		--big-font-size: clamp(3rem, 7vw, 5.75rem);
		--h1-font-size: 1.5rem;
		--h2-font-size: 1.25rem;
		--h3-font-size: 1.125rem;
		--normal-font-size: 0.938rem;
		--small-font-size: 0.9rem;
		--gap-1: 1rem;
		--gap-2: 2rem;
		--gap-3: 3rem;
		--gap-4: 4rem;
		--smaller-font-size: 0.75rem;
		--font-medium: 500;
		--font-semi-bold: 600;
		--mb-0-25: 0.25rem;
		--mb-0-5: 0.5rem;
		--mb-0-75: 0.75rem;
		--mb-1: 1rem;
		--mb-1-5: 1.5rem;
		--mb-2: 2rem;
		--mb-2-5: 2.5rem;
		--mb-3: 3rem;
		--z-tooltip: 10;
		--z-fixed: 100;
		--z-modal: 1000;
		--constras-color: #eee7e1;
		--box-shadow: 0 1px 3px rgba(65, 38, 22, 0.1);
		--box-shadow-hover: 0 4px 8px rgba(65, 38, 22, 0.12);
		--section-space: clamp(6rem, 11vw, 10rem);
	}

	@media screen and (min-width: 968px) {
		:root {
			--big-font-size: 3rem;
			--h1-font-size: 2.25rem;
			--h2-font-size: 1.5rem;
			--h3-font-size: 1.25rem;
			--normal-font-size: 1rem;
			--small-font-size: 0.875rem;
			--smaller-font-size: 0.813rem;
		}
	}

	body.darkTheme {
		--first-color: #ff8b4f;
		--first-color-alt: #ffab7d;
		--first-color-second: #ff8b4f;
		--title-color: #f6f3f0;
		--text-color: #c3bdb7;
		--text-color-light: #aaa29a;
		--input-color: #25211e;
		--body-color: #171513;
		--container-color: #211e1b;
		--scroll-bar-color: hsl(var(--hue-color), 12%, 48%);
		--scroll-thumb-color: hsl(var(--hue-color), 12%, 36%);
		--border-color: rgba(255, 243, 235, 0.14);
		--constras-color: #302720;
	}

	@supports selector(::-webkit-scrollbar) {
		@media (hover: hover) {
			::-webkit-scrollbar {
				width: 10px;
				border-radius: 10px;
			}

			::-webkit-scrollbar-thumb {
				border-radius: 10px;
				background-color: #888;
				border: 2px solid transparent;
				background-clip: content-box;
			}

			::-webkit-scrollbar-thumb:active {
				background-color: #666;
			}
		}
	}

	@supports not selector(::-webkit-scrollbar) {
		* {
			scrollbar-color: #888 transparent;
			scrollbar-width: thin;
		}
	}

	@font-face {
		font-family: "Cascadia Code";
		src: url("/Cascadia.ttf") format("truetype");
		display: swap;
	}

	* {
		box-sizing: border-box;
		padding: 0;
		margin: 0;
	}

	html {
		scroll-behavior: smooth;
		scroll-padding-top: calc(var(--header-height) + 1rem);
	}

	body {
		margin: 0;
		font-family: var(--body-font);
		font-size: var(--normal-font-size);
		background-color: var(--body-color);
		color: var(--text-color);
		line-height: 1.7;
		-webkit-font-smoothing: antialiased;
		transition: background-color 0.25s ease, color 0.25s ease;
		overflow-x: clip;
	}

	h1,
	h2,
	h3,
	h4 {
		color: var(--title-color);
		font-weight: var(--font-semi-bold);
		line-height: 1.12;
		letter-spacing: -0.025em;
		text-wrap: balance;
	}

	p {
		text-wrap: pretty;
	}

	ul {
		list-style: none;
	}

	a {
		text-decoration: none;
	}

	a, button {
		-webkit-tap-highlight-color: transparent;
	}

	:focus-visible {
		outline: 3px solid var(--first-color);
		outline-offset: 4px;
	}

	img {
		max-width: 100%;
		height: auto;
	}

	main {
		display: block;
		margin: 0 auto;
		max-width: 1200px;
		padding: 0 0 var(--section-space);
	}

	section {
		padding-top: var(--section-space);
	}

	section:first-child {
		padding-top: var(--header-height);
	}

	@media screen and (max-width: 1248px) {
		main {
			padding: 0px 2rem;
		}
	}

	.content-wrapper {
		transition:
			filter 0.18s ease,
			transform 0.18s ease;
		min-height: 100vh;
		position: relative;
		z-index: 1;
		overflow: clip;
	}

	::selection {
		background: var(--first-color);
		color: #fff;
	}

	.skip-link {
		position: fixed;
		z-index: 1000;
		top: 0.75rem;
		left: 0.75rem;
		padding: 0.75rem 1rem;
		background: var(--title-color);
		color: var(--body-color);
		transform: translateY(-150%);
	}

	.skip-link:focus {
		transform: translateY(0);
	}

	@media (prefers-reduced-motion: reduce) {
		html {
			scroll-behavior: auto;
		}

		*, *::before, *::after {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
		}
	}
</style>
